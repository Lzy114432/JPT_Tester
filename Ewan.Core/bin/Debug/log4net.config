<?xml version="1.0" encoding="utf-8" ?>
<log4net>
	<root>
		<level value="ALL" />
		<appender-ref ref="LogFileAppender" />
		<appender-ref ref="ColoredConsoleAppender"/>
	</root>
	
	<!-- UI操作日志配置 -->
	<logger name="UILogger" additivity="false">
		<level value="ALL" />
		<appender-ref ref="UILogAppender" />
	</logger>
	
	<!-- IO操作专用日志配置 -->
	<logger name="IOLogger" additivity="false">
		<level value="ALL" />
		<appender-ref ref="IOLogAppender" />
	</logger>
	
	<!--定义输出到文件-->
	<appender name ="LogFileAppender" type="log4net.Appender.RollingFileAppender">
		<!--定义文件存放位置-->
		<param name="File" value ="Logs\app.log"/>
		<param name="AppendToFile" value="true" />
		<param name="Encoding" value="utf-8" />
		<param name="MaxSizeRollBackups" value="100" />
		<param name="MaxFileSize" value="104857600" />
		<param name="StaticLogFileName" value="false" />
		<!--文件名格式-->
		<param name="DatePattern" value="yyyy-MM-dd'.txt'" />
		<param name="RollingStyle" value ="Date"/>
		<!--不以独占方式记录日志,仅在记录每个日志的最短时间内锁定,因为部署到服务器上遇到了文件被占用无法下载日志-->
		<lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
		<layout type="log4net.Layout.PatternLayout">
			<!--定义输出格式，移除[%class:%L]避免显示UILogger内部行号-->
			<!--示例 2018-08-20 12:10:49,348 [INFO] [thread-21] 日志信息-->
			<param name="ConversionPattern" value="%date [%-5level] [thread-%thread] %message %newline"/>
		</layout>
		<!--过滤级别 OFF > FATAL > ERROR > WARN > INFO > DEBUG  > ALL-->
		<threshold value="ALL"/>
	</appender>

	<!-- 控制台前台显示日志 -->
	<appender name="ColoredConsoleAppender" type="log4net.Appender.ColoredConsoleAppender">
		<mapping>
			<level value="ERROR" />
			<foreColor value="Red, HighIntensity" />
		</mapping>
		<mapping>
			<level value="Info" />
			<foreColor value="Green" />
		</mapping>
		<layout type="log4net.Layout.PatternLayout">
			<!--定义输出格式，移除[%class:%L]避免显示UILogger内部行号-->
			<!--示例 2018-08-20 12:10:49,348 [INFO] [thread-21] 日志信息-->
			<param name="ConversionPattern" value="%date [%-5level] [thread-%thread] %message %newline"/>
		</layout>
		<threshold value="WARN"/>
	</appender>
	
	<!-- IO操作日志输出到独立文件 -->
	<appender name="IOLogAppender" type="log4net.Appender.RollingFileAppender">
		<!--定义文件存放位置-->
		<param name="File" value ="IOLogs\io.log"/>
		<param name="AppendToFile" value="true" />
		<param name="Encoding" value="utf-8" />
		<param name="MaxSizeRollBackups" value="100" />
		<param name="MaxFileSize" value="104857600" />
		<param name="StaticLogFileName" value="false" />
		<!--文件名格式-->
		<param name="DatePattern" value="yyyy-MM-dd'.txt'" />
		<param name="RollingStyle" value ="Date"/>
		<!--不以独占方式记录日志,仅在记录每个日志的最短时间内锁定,因为部署到服务器上遇到了文件被占用无法下载日志-->
		<lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
		<layout type="log4net.Layout.PatternLayout">
			<!--定义输出格式-->
			<!--示例 2018-08-20 12:10:49,348 [INFO] [thread-21] 日志信息-->
			<param name="ConversionPattern" value="%date [%-5level] [thread-%thread] %message %newline"/>
		</layout>
		<!--过滤级别 OFF > FATAL > ERROR > WARN > INFO > DEBUG  > ALL-->
		<threshold value="ALL"/>
	</appender>
	
	<!-- UI日志输出到独立文件 -->
	<appender name="UILogAppender" type="log4net.Appender.RollingFileAppender">
		<!--定义文件存放位置-->
		<param name="File" value ="UILogs\ui.log"/>
		<param name="AppendToFile" value="true" />
		<param name="Encoding" value="utf-8" />
		<param name="MaxSizeRollBackups" value="100" />
		<param name="MaxFileSize" value="104857600" />
		<param name="StaticLogFileName" value="false" />
		<!--文件名格式-->
		<param name="DatePattern" value="yyyy-MM-dd'.txt'" />
		<param name="RollingStyle" value ="Date"/>
		<!--不以独占方式记录日志,仅在记录每个日志的最短时间内锁定,因为部署到服务器上遇到了文件被占用无法下载日志-->
		<lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
		<layout type="log4net.Layout.PatternLayout">
			<!--定义输出格式-->
			<!--示例 2018-08-20 12:10:49,348 [INFO] [thread-21] 日志信息-->
			<param name="ConversionPattern" value="%date [%-5level] [thread-%thread] %message %newline"/>
		</layout>
		<!--过滤级别 OFF > FATAL > ERROR > WARN > INFO > DEBUG  > ALL-->
		<threshold value="ALL"/>
	</appender>
	
	<!-- 自定义日志输出示例 -->
	<appender name="CustomAppender" type="log4net.Appender.RollingFileAppender">
		<param name="File" value ="Logs\custom.log"/>
		<param name="AppendToFile" value="true"/>
		<param name="Encoding" value="utf-8" />
		<param name="MaxSizeRollBackups" value="100"/>
		<param name="MaxFileSize" value="10240" />
		<param name="StaticLogFileName" value="false"/>
		<param name="DatePattern" value="yyyy-MM-dd'.csv'" />
		<param name="RollingStyle" value="Date"/>
		<lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
		<layout type="log4net.Layout.PatternLayout">
			<param name="Header" value="Time,Thread,Level,Logger,Message,Exception&#13;&#10;" />
			<param name="ConversionPattern" value="%d,%m,%n"/>
		</layout>
	</appender>
</log4net>