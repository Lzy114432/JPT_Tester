<Window x:Class="MarkingMachineFeeder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkingMachineFeeder"
        xmlns:controls="clr-namespace:MarkingMachineFeeder.Windows"
        xmlns:vm="clr-namespace:MarkingMachineFeeder.Viewmodel"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="900" Width="1200"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=False}">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Top Menu Bar -->
        <DockPanel Grid.Row="0" Background="#F5F5F5">
            <Menu DockPanel.Dock="Left" Visibility="{Binding CanSwitchLanguage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <MenuItem Header="{Binding LanguageMenuHeader}">
                    <MenuItem Header="English" Command="{Binding SwitchLanguageCommand}" CommandParameter="en-US"/>
                    <MenuItem Header="中文" Command="{Binding SwitchLanguageCommand}" CommandParameter="zh-CN"/>
                </MenuItem>
                <MenuItem Header="{Binding SystemManagementMenuHeader}" Visibility="{Binding CanViewSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <MenuItem Header="{Binding PermissionConfigMenuHeader}" Command="{Binding OpenPermissionConfigCommand}"/>
                </MenuItem>
            </Menu>
            
            <!-- 用户信息区域 - 居中显示 -->
            <Border DockPanel.Dock="Top" Background="#E8E8E8" Padding="10,5" Margin="5,2">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentUserText}" 
                              VerticalAlignment="Center" 
                              FontWeight="Bold" 
                              Foreground="#333333"
                              Margin="0,0,15,0"/>
                    <Button Content="{Binding SwitchUserButtonText}" 
                            Command="{Binding SwitchUserCommand}" 
                            Width="80" Height="25" Margin="5,0"/>
                </StackPanel>
            </Border>
            
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="10,5">
                <Button Content="{Binding TestLogButtonText}" Command="{Binding TestLogCommand}" 
                        Width="120" Height="25" Margin="5,0"/>
            </StackPanel>
        </DockPanel>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200" MinWidth="150"/>
            </Grid.ColumnDefinitions>
        
        <!-- Left Panel - UPS -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="5">
            <Grid>
                <TextBlock Text="UPS 区域" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5" FontWeight="Bold"/>
                <!-- UPS content will be added here -->
            </Grid>
        </Border>
        
        <!-- Middle Panel - Camera (Top) and Log (Bottom) -->
        <Grid Grid.Column="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Camera Section -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,2.5">
                <Grid>
                    <TextBlock Text="相机区域" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5" FontWeight="Bold"/>
                    <!-- Camera content will be added here -->
                </Grid>
            </Border>
            
            <!-- Log Section -->
            <Grid Grid.Row="1" Margin="0,2.5,0,0">
                <controls:LogWindow/>
            </Grid>
        </Grid>
        
        <!-- Right Panel - Reserved -->
        <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="5">
            <Grid>
                <TextBlock Text="预留区域" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5" FontWeight="Bold"/>
                <!-- Reserved content will be added here -->
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
