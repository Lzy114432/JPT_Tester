<Window x:Class="MarkingMachineFeeder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkingMachineFeeder"
        xmlns:controls="clr-namespace:MarkingMachineFeeder.Windows"
        xmlns:vm="clr-namespace:MarkingMachineFeeder.Viewmodel"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="900" Width="1200"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=False}">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Top Menu Area (Upper & Lower) -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 上部菜单栏 -->
                <RowDefinition Height="Auto"/>  <!-- 下部菜单栏 -->
            </Grid.RowDefinitions>
            
            <!-- 上部菜单栏 - 包含语言切换和系统管理 -->
            <DockPanel Grid.Row="0" Background="#F0F0F0" LastChildFill="True">
                <!-- 左侧 - 设置和系统菜单 -->
                <Menu DockPanel.Dock="Left" Background="Transparent" Margin="10,2,5,2">
                    <!-- 设置菜单 -->
                    <MenuItem Header="{Binding SettingsMenuHeader}" 
                              d:Header="设置"
                              Command="{Binding OpenSettingsCommand}"/>
                    
                    <!-- 系统菜单 -->
                    <MenuItem Header="{Binding SystemMenuHeader}"
                              d:Header="系统">
                        <!-- 系统设置项 -->
                        <MenuItem Header="{Binding SystemSettingsMenuHeader}" 
                                  d:Header="系统设置"
                                  Command="{Binding OpenSystemCommand}"/>
                        <!-- 权限配置菜单 -->
                        <MenuItem Header="{Binding PermissionConfigMenuHeader}" 
                                  d:Header="权限配置"
                                  Command="{Binding OpenPermissionConfigCommand}"
                                  Visibility="{Binding CanViewSettings, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <!-- 语言切换子菜单 -->
                        <MenuItem Header="{Binding LanguageMenuHeader}"
                                  d:Header="语言"
                                  Visibility="{Binding CanSwitchLanguage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <MenuItem Header="English" Command="{Binding SwitchLanguageCommand}" CommandParameter="en-US"/>
                            <MenuItem Header="中文" Command="{Binding SwitchLanguageCommand}" CommandParameter="zh-CN"/>
                        </MenuItem>
                    </MenuItem>
                </Menu>
                
                <!-- 右侧 - 用户信息 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,5,10,5">
                    <TextBlock Text="{Binding CurrentUserLabel}" 
                              d:Text="当前用户："
                              VerticalAlignment="Center" 
                              FontWeight="Medium" 
                              Foreground="#444444"/>
                    <TextBlock Text="{Binding CurrentUser}" 
                              d:Text="游客"
                              VerticalAlignment="Center" 
                              FontWeight="Bold" 
                              Foreground="#333333"
                              Margin="5,0,0,0"/>
                </StackPanel>
                
                <!-- 填充空间 -->
                <Grid/>
            </DockPanel>
            
            <!-- 下部菜单栏 - 包含操作按钮 -->
            <DockPanel Grid.Row="1" Background="#E8E8E8" LastChildFill="True">
                <!-- 右侧 - 注销和登录按钮 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="10,5">
                    <Button Content="{Binding LogoutButtonText}" 
                            d:Content="注销"
                            Command="{Binding LogoutCommand}" 
                            Width="80" Height="26" Margin="5,0"/>
                    <Button Content="{Binding LoginButtonText}" 
                            d:Content="登录"
                            Command="{Binding LoginCommand}" 
                            Width="80" Height="26" Margin="5,0"/>
                </StackPanel>
                
                <!-- 左侧 - 测试日志按钮 -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="10,5">
                    <Button Content="{Binding TestLogButtonText}" 
                            d:Content="测试日志"
                            Command="{Binding TestLogCommand}" 
                            Width="120" Height="26" Margin="0,0,5,0"/>
                </StackPanel>
                
                <!-- 填充空间 -->
                <Grid/>
            </DockPanel>
        </Grid>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200" MinWidth="150"/>
            </Grid.ColumnDefinitions>
        
        <!-- Left Panel - UPS -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="5">
            <Grid>
                <TextBlock Text="UPS 区域" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5" FontWeight="Bold"/>
                <!-- UPS content will be added here -->
            </Grid>
        </Border>
        
        <!-- Middle Panel - Camera (Top) and Log (Bottom) -->
        <Grid Grid.Column="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Camera Section -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,2.5">
                <Grid>
                    <TextBlock Text="相机区域" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5" FontWeight="Bold"/>
                    <!-- Camera content will be added here -->
                </Grid>
            </Border>
            
            <!-- Log Section -->
            <Grid Grid.Row="1" Margin="0,2.5,0,0">
                <controls:LogWindow/>
            </Grid>
        </Grid>
        
        <!-- Right Panel - Reserved -->
        <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="5">
            <Grid>
                <TextBlock Text="预留区域" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5" FontWeight="Bold"/>
                <!-- Reserved content will be added here -->
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
