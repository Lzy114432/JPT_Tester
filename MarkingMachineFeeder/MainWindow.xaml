<Window x:Class="MarkingMachineFeeder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkingMachineFeeder"
        xmlns:controls="clr-namespace:MarkingMachineFeeder.Windows"
        xmlns:vm="clr-namespace:MarkingMachineFeeder.Viewmodel"
        xmlns:ewanControls="clr-namespace:Ewan.Controls;assembly=Ewan.Controls"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="1000" Width="1400"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderBrush="Transparent"
        BorderThickness="0"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=False}">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Industrial Background Gradient -->
        <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#4682B4" Offset="0"/>
            <GradientStop Color="#36648B" Offset="0.5"/>
            <GradientStop Color="#27408B" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- Industrial Menu Item Style -->
        <Style x:Key="IndustrialMenuItem" TargetType="MenuItem">
            <Setter Property="Background" Value="{StaticResource BackgroundGradient}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8,28,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.3" ShadowDepth="2" BlurRadius="4"/>
                            </Border.Effect>
                            <Grid>
                                <!-- Header Content -->
                                <ContentPresenter x:Name="HeaderHost" 
                                                ContentSource="Header" 
                                                Margin="{TemplateBinding Padding}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                RecognizesAccessKey="True"/>
                                <!-- Submenu Arrow -->
                                <Path x:Name="ArrowPath" 
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Right" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,6,0"
                                      Fill="{TemplateBinding Foreground}"
                                      Data="M0,0 L4,4 L0,8 Z"/>
                                <!-- Popup for submenu -->
                                <Popup x:Name="SubMenuPopup" 
                                       Placement="Bottom" 
                                       IsOpen="{Binding Path=IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       AllowsTransparency="True" 
                                       Focusable="False">
                                    <Border Background="{StaticResource BackgroundGradient}" 
                                            BorderBrush="#666666" 
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Margin="0,0,5,5">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Opacity="0.4" ShadowDepth="3" BlurRadius="6"/>
                                        </Border.Effect>
                                        <StackPanel IsItemsHost="True" 
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    Margin="2"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Has submenu items -->
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="ArrowPath" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <!-- Mouse over effect -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#5A5A5A" Offset="0"/>
                                            <GradientStop Color="#3D3D40" Offset="0.5"/>
                                            <GradientStop Color="#2E2E2E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#777777"/>
                                <Setter Property="Foreground" Value="#FFFF00"/>
                            </Trigger>
                            <!-- Pressed effect -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#3A3A3A" Offset="0"/>
                                            <GradientStop Color="#1D1D20" Offset="0.5"/>
                                            <GradientStop Color="#0E0E0E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#999999"/>
                            </Trigger>
                            <!-- Disabled effect -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#666666"/>
                                <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Industrial Sub Menu Item Style -->
        <Style x:Key="IndustrialSubMenuItem" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <!-- Header Content -->
                                <ContentPresenter x:Name="HeaderPresenter" 
                                                ContentSource="Header"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,20,0"/>
                                <!-- Submenu Arrow for nested items -->
                                <Path x:Name="ArrowPath" 
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Right" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,5,0"
                                      Fill="{TemplateBinding Foreground}"
                                      Data="M0,0 L4,4 L0,8 Z"/>
                                <!-- Popup for nested submenu -->
                                <Popup x:Name="SubMenuPopup" 
                                       Placement="Right" 
                                       IsOpen="{Binding Path=IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       AllowsTransparency="True" 
                                       Focusable="False"
                                       HorizontalOffset="2"
                                       VerticalOffset="-3">
                                    <Border Background="{StaticResource BackgroundGradient}" 
                                            BorderBrush="#666666" 
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Margin="0,0,5,5">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Opacity="0.4" ShadowDepth="3" BlurRadius="6"/>
                                        </Border.Effect>
                                        <StackPanel IsItemsHost="True" 
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"
                                                    Margin="2"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Has submenu items -->
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="ArrowPath" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4A4A4A"/>
                                <Setter Property="Foreground" Value="#FFFF00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Industrial Test Button Style -->
        <Style x:Key="IndustrialTestButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BackgroundGradient}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="true">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="1" BlurRadius="3"/>
                            </Border.Effect>
                            <ContentPresenter x:Name="contentPresenter" 
                                            Focusable="False" 
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            Margin="{TemplateBinding Padding}" 
                                            RecognizesAccessKey="True" 
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDefaulted" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#5A5A5A" Offset="0"/>
                                            <GradientStop Color="#3D3D40" Offset="0.5"/>
                                            <GradientStop Color="#2E2E2E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="BorderBrush" Value="#777777"/>
                                <Setter Property="Foreground" Value="#FFFF00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#3A3A3A" Offset="0"/>
                                            <GradientStop Color="#1D1D20" Offset="0.5"/>
                                            <GradientStop Color="#0E0E0E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="BorderBrush" Value="#999999"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#F4F4F4"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E0E0E0"/>
                                <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="#999999"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="true">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="1" BlurRadius="3"/>
                            </Border.Effect>
                            <ContentPresenter x:Name="contentPresenter" 
                                            Focusable="False" 
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            Margin="{TemplateBinding Padding}" 
                                            RecognizesAccessKey="True" 
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDefaulted" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#F8F8F8" Offset="0"/>
                                            <GradientStop Color="#E8E8E8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="BorderBrush" TargetName="border" Value="#999999"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#D8D8D8" Offset="0"/>
                                            <GradientStop Color="#C8C8C8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="BorderBrush" TargetName="border" Value="#777777"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Background" TargetName="border" Value="#F4F4F4"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="#E0E0E0"/>
                                <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="#999999"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Logout Button Style (Red Theme) -->
        <Style x:Key="LogoutButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0"/>
                        <GradientStop Color="#E8E8E8" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#C62D42"/>
            <Setter Property="BorderBrush" Value="#D4A5A5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFE8E8" Offset="0"/>
                                <GradientStop Color="#FFD8D8" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#C62D42"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFD0D0" Offset="0"/>
                                <GradientStop Color="#FFC0C0" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Login Button Style (Blue Theme) -->
        <Style x:Key="LoginButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F8FF" Offset="0"/>
                        <GradientStop Color="#E0E8F0" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#2E5BBA"/>
            <Setter Property="BorderBrush" Value="#A5C4E4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#E8F4FF" Offset="0"/>
                                <GradientStop Color="#D8E8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#2E5BBA"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#D0E8FF" Offset="0"/>
                                <GradientStop Color="#C0D8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Top Menu Area (Upper & Lower) -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 上部菜单栏 -->
                <RowDefinition Height="Auto"/>  <!-- 下部菜单栏 -->
            </Grid.RowDefinitions>
            
            <!-- 上部菜单栏 - 包含语言切换和系统管理 -->
            <DockPanel Grid.Row="0" Background="{StaticResource BackgroundGradient}" LastChildFill="True" MouseLeftButtonDown="DockPanel_MouseLeftButtonDown">
                <!-- 左侧 - 设置和系统菜单 -->
                <Menu DockPanel.Dock="Left" Background="Transparent" Margin="15,8,10,8">
                    <!-- 设置菜单 -->
                    <MenuItem Header="{Binding SettingsMenuHeader}" 
                              d:Header="设置"
                              Style="{StaticResource IndustrialMenuItem}">
                        <!-- 硬件控制菜单 -->
                        <MenuItem Header="{Binding HardwareControlMenuHeader}" 
                                  d:Header="硬件控制"
                                  Style="{StaticResource IndustrialSubMenuItem}"
                                  Visibility="{Binding CanAccessHardwareControl, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- IO控制子菜单 -->
                            <MenuItem Header="{Binding IOControlMenuHeader}" 
                                      d:Header="IO控制"
                                      Command="{Binding OpenIOControlCommand}"
                                      Style="{StaticResource IndustrialSubMenuItem}"/>
                            <!-- IO映射配置子菜单 -->
                            <MenuItem Header="{Binding IOMappingConfigMenuHeader}" 
                                      d:Header="IO映射配置"
                                      Command="{Binding OpenIOMappingConfigCommand}"
                                      Style="{StaticResource IndustrialSubMenuItem}"/>
                            <!-- 轴配置子菜单 -->
                            <MenuItem Header="{Binding AxisConfigMenuHeader}" 
                                      d:Header="轴配置"
                                      Command="{Binding OpenAxisConfigCommand}"
                                      Style="{StaticResource IndustrialSubMenuItem}"/>
                            <!-- 轴手动控制子菜单 -->
                            <MenuItem Header="{Binding AxisControlMenuHeader}" 
                                      d:Header="轴手动控制"
                                      Command="{Binding OpenAxisControlCommand}"
                                      Style="{StaticResource IndustrialSubMenuItem}"/>
                        </MenuItem>
                    </MenuItem>
                    
                    <!-- 系统菜单 -->
                    <MenuItem Header="{Binding SystemMenuHeader}"
                              d:Header="系统"
                              Style="{StaticResource IndustrialMenuItem}">
                        <!-- 权限配置菜单 -->
                        <MenuItem Header="{Binding PermissionConfigMenuHeader}" 
                                  d:Header="权限配置"
                                  Command="{Binding OpenPermissionConfigCommand}"
                                  Style="{StaticResource IndustrialSubMenuItem}"
                                  Visibility="{Binding CanViewSettings, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <!-- 语言切换子菜单 -->
                        <MenuItem Header="{Binding LanguageMenuHeader}"
                                  d:Header="语言"
                                  Style="{StaticResource IndustrialSubMenuItem}"
                                  Visibility="{Binding CanSwitchLanguage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <MenuItem Header="English" 
                                      Command="{Binding SwitchLanguageCommand}" 
                                      CommandParameter="en-US"
                                      Style="{StaticResource IndustrialSubMenuItem}"/>
                            <MenuItem Header="中文" 
                                      Command="{Binding SwitchLanguageCommand}" 
                                      CommandParameter="zh-CN"
                                      Style="{StaticResource IndustrialSubMenuItem}"/>
                        </MenuItem>
                        <!-- 退出菜单 -->
                        <MenuItem Header="{Binding ExitMenuHeader}" 
                                  d:Header="退出"
                                  Command="{Binding ExitCommand}"
                                  Style="{StaticResource IndustrialSubMenuItem}"
                                  Visibility="{Binding CanExit, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </MenuItem>
                </Menu>
                
                <!-- 右侧 - 用户信息 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,8,15,8">
                    <TextBlock Text="{Binding CurrentUserLabel}" 
                              d:Text="当前用户："
                              VerticalAlignment="Center" 
                              FontWeight="Medium" 
                              Foreground="#CCCCCC"
                              FontSize="13"/>
                    <TextBlock Text="{Binding CurrentUser}" 
                              d:Text="游客"
                              VerticalAlignment="Center" 
                              FontWeight="Bold" 
                              Foreground="#FFFFFF"
                              FontSize="13"
                              Margin="8,0,0,0"/>
                </StackPanel>
                
                <!-- 填充空间 -->
                <Grid/>
            </DockPanel>
            
            <!-- 下部菜单栏 - 包含操作按钮 -->
            <DockPanel Grid.Row="1" Background="{StaticResource BackgroundGradient}" LastChildFill="True" MouseLeftButtonDown="DockPanel_MouseLeftButtonDown">
                <!-- 右侧 - 登录按钮 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="15,8">
                    <Button Content="{Binding LoginButtonText}" 
                            d:Content="登录"
                            Command="{Binding LoginCommand}" 
                            Style="{StaticResource LoginButton}"
                            Width="90" Height="32" 
                            Margin="5,0"/>
                </StackPanel>
                
                <!-- 左侧 - 测试日志按钮 -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="15,8">
                    <Button Content="{Binding TestLogButtonText}" 
                            d:Content="测试日志"
                            Command="{Binding TestLogCommand}" 
                            Style="{StaticResource IndustrialTestButton}"
                            Width="120" Height="32" Margin="0,0,10,0"/>
                </StackPanel>
                
                <!-- 填充空间 -->
                <Grid/>
            </DockPanel>
        </Grid>
        
        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200" MinWidth="150"/>
            </Grid.ColumnDefinitions>
        
        <!-- Left Panel - Using UserControls -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="2.5*"/>
                    <RowDefinition Height="0.8*"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <TextBlock Grid.Row="0" Text="系统控制面板" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5" FontWeight="Bold" FontSize="14"/>
                
                <!-- Safety IO Panel -->
                <controls:SafetyIOPanel Grid.Row="1" />
                
                <!-- Interactive IO Panel -->
                <controls:InteractiveIOPanel Grid.Row="2" />
                
                <!-- Robot Control Panel -->
                <controls:RobotControlPanel Grid.Row="3" />
                
            </Grid>
        </Border>
        
        <!-- Middle Panel - Camera (Top) and Log (Bottom) -->
        <Grid Grid.Column="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Camera Section -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,2.5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left Side - UPH Section -->
                    <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,0" Margin="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- UPH Header -->
                            <TextBlock Grid.Row="0" Text="生产效率(UPH)" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center" 
                                      Margin="5" 
                                      FontWeight="Bold" 
                                      FontSize="16"
                                      Foreground="#2E5BBA"/>
                            
                            <!-- UPH Display -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 上料 UPH -->
                                <Border Grid.Row="0" Background="#F0F8FF" Margin="10,10" CornerRadius="8" BorderBrush="#4682B4" BorderThickness="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="上料:" VerticalAlignment="Center" Margin="10,0" FontSize="14" FontWeight="Medium"/>
                                        <TextBlock Grid.Column="1" Text="{Binding LoadingUPH, FallbackValue='1,250'}" 
                                                  VerticalAlignment="Center" 
                                                  HorizontalAlignment="Right" 
                                                  Margin="0,0,10,0" 
                                                  FontSize="20" 
                                                  FontWeight="Bold" 
                                                  Foreground="#2E5BBA"/>
                                    </Grid>
                                </Border>
                                
                                <!-- 下料 UPH -->
                                <Border Grid.Row="1" Background="#F0FFF0" Margin="10,10" CornerRadius="8" BorderBrush="#32CD32" BorderThickness="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="下料:" VerticalAlignment="Center" Margin="10,0" FontSize="14" FontWeight="Medium"/>
                                        <TextBlock Grid.Column="1" Text="{Binding UnloadingUPH, FallbackValue='1,180'}" 
                                                  VerticalAlignment="Center" 
                                                  HorizontalAlignment="Right" 
                                                  Margin="0,0,10,0" 
                                                  FontSize="20" 
                                                  FontWeight="Bold" 
                                                  Foreground="#228B22"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                    
                    <!-- Right Side - Material Section -->
                    <Grid Grid.Column="1" Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Material Header -->
                        <TextBlock Grid.Row="0" Text="物料管理" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Margin="2" 
                                  FontWeight="Bold" 
                                  FontSize="14"
                                  Foreground="#2E5BBA"/>
                        
                        <!-- A料 -->
                        <Border Grid.Row="1" Background="#E6F3FF" Margin="2,1" CornerRadius="4" BorderBrush="#87CEEB" BorderThickness="1">
                            <Grid Margin="6,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="25"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button Grid.Column="0" Content="清料" 
                                       Style="{StaticResource ModernButton}" 
                                       Width="46" Height="26" 
                                       FontSize="10" FontWeight="Bold"
                                       Command="{Binding MaterialA_ClearCommand}"
                                       ToolTip="清空A料"
                                       Margin="0"/>
                                <TextBlock Grid.Column="1" Text="A料:" VerticalAlignment="Center" FontWeight="Bold" FontSize="12" Foreground="#4682B4" Margin="4,0,6,0"/>
                                <TextBox Grid.Column="2" Text="{Binding MaterialA_Barcode, FallbackValue='A240912001'}" 
                                        VerticalAlignment="Center" FontSize="11" Padding="4,2" Margin="0,0,6,0" Height="26"/>
                                <TextBlock Grid.Column="3" Text="计数:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="4" Text="{Binding MaterialA_Count, FallbackValue='150'}" 
                                        VerticalAlignment="Center" FontSize="11" Padding="4,2" Margin="0,0,6,0" Height="26"/>
                                <TextBlock Grid.Column="5" Text="优先级:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="6" Text="{Binding MaterialA_Priority, FallbackValue='1'}" 
                                        VerticalAlignment="Center" FontSize="11" Padding="4,2" Margin="0,0,4,0" Height="26"/>
                                <Button Grid.Column="7" Content="↑" 
                                       Style="{StaticResource ModernButton}" 
                                       Width="22" Height="26" 
                                       FontSize="10" FontWeight="Bold"
                                       Command="{Binding MaterialA_IncreasePriorityCommand}"
                                       ToolTip="提升A料优先级"
                                       Margin="0"/>
                            </Grid>
                        </Border>
                        
                        <!-- B料 -->
                        <Border Grid.Row="2" Background="#F0FFF0" Margin="2,1" CornerRadius="4" BorderBrush="#90EE90" BorderThickness="1">
                            <Grid Margin="6,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="25"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button Grid.Column="0" Content="清料" 
                                       Style="{StaticResource ModernButton}" 
                                       Width="46" Height="26" 
                                       FontSize="10" FontWeight="Bold"
                                       Command="{Binding MaterialB_ClearCommand}"
                                       ToolTip="清空B料"
                                       Margin="0"/>
                                <TextBlock Grid.Column="1" Text="B料:" VerticalAlignment="Center" FontWeight="Bold" FontSize="12" Foreground="#228B22" Margin="4,0,6,0"/>
                                <TextBox Grid.Column="2" Text="{Binding MaterialB_Barcode, FallbackValue='B240912002'}" 
                                        VerticalAlignment="Center" FontSize="11" Padding="4,2" Margin="0,0,6,0" Height="26"/>
                                <TextBlock Grid.Column="3" Text="计数:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="4" Text="{Binding MaterialB_Count, FallbackValue='89'}" 
                                        VerticalAlignment="Center" FontSize="11" Padding="4,2" Margin="0,0,6,0" Height="26"/>
                                <TextBlock Grid.Column="5" Text="优先级:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="6" Text="{Binding MaterialB_Priority, FallbackValue='2'}" 
                                        VerticalAlignment="Center" FontSize="11" Padding="4,2" Margin="0,0,4,0" Height="26"/>
                                <Button Grid.Column="7" Content="↑" 
                                       Style="{StaticResource ModernButton}" 
                                       Width="22" Height="26" 
                                       FontSize="10" FontWeight="Bold"
                                       Command="{Binding MaterialB_IncreasePriorityCommand}"
                                       ToolTip="提升B料优先级"
                                       Margin="0"/>
                            </Grid>
                        </Border>
                        
                        <!-- NG料 -->
                        <Border Grid.Row="3" Background="#FFF0F0" Margin="2,1" CornerRadius="4" BorderBrush="#FFB6C1" BorderThickness="1">
                            <Grid Margin="6,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="25"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button Grid.Column="0" Content="清料" 
                                       Style="{StaticResource ModernButton}" 
                                       Width="46" Height="26" 
                                       FontSize="10" FontWeight="Bold"
                                       Command="{Binding MaterialNG_ClearCommand}"
                                       ToolTip="清空NG料"
                                       Margin="0"/>
                                <TextBlock Grid.Column="1" Text="NG料:" VerticalAlignment="Center" FontWeight="Bold" FontSize="12" Foreground="#DC143C" Margin="4,0,6,0"/>
                                <TextBox Grid.Column="2" Text="{Binding MaterialNG_Barcode, FallbackValue='NG240912003'}" 
                                        VerticalAlignment="Center" FontSize="11" Padding="4,2" Margin="0,0,6,0" Height="26"/>
                                <TextBlock Grid.Column="3" Text="计数:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="4" Text="{Binding MaterialNG_Count, FallbackValue='12'}" 
                                        VerticalAlignment="Center" FontSize="11" Padding="4,2" Margin="0,0,6,0" Height="26"/>
                                <TextBlock Grid.Column="5" Text="优先级:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="6" Text="{Binding MaterialNG_Priority, FallbackValue='3'}" 
                                        VerticalAlignment="Center" FontSize="11" Padding="4,2" Margin="0,0,4,0" Height="26"/>
                                <Button Grid.Column="7" Content="↑" 
                                       Style="{StaticResource ModernButton}" 
                                       Width="22" Height="26" 
                                       FontSize="10" FontWeight="Bold"
                                       Command="{Binding MaterialNG_IncreasePriorityCommand}"
                                       ToolTip="提升NG料优先级"
                                       Margin="0"/>
                            </Grid>
                        </Border>
                        
                        <!-- Material Inventory Panel -->
                        <GroupBox Grid.Row="4" Header="设备物料库存" Margin="2,8,2,4" Padding="6" 
                                 FontSize="12" FontWeight="Medium" Foreground="#2E5BBA">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Material Inventory Status -->
                                <Grid Grid.Row="0" Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- A Material Inventory -->
                                    <Border Grid.Column="0" Background="#E6F3FF" Margin="1" Padding="6,8" CornerRadius="4" BorderBrush="#87CEEB" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="A料库存" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" Foreground="#4682B4"/>
                                            <TextBlock Text="{Binding MaterialA_Count, FallbackValue='150'}" 
                                                      FontWeight="Bold" FontSize="16" Foreground="#4682B4" 
                                                      HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            <TextBlock Text="件" FontSize="9" HorizontalAlignment="Center" Foreground="#4682B4"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- B Material Inventory -->
                                    <Border Grid.Column="1" Background="#F0FFF0" Margin="1" Padding="6,8" CornerRadius="4" BorderBrush="#90EE90" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="B料库存" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" Foreground="#228B22"/>
                                            <TextBlock Text="{Binding MaterialB_Count, FallbackValue='89'}" 
                                                      FontWeight="Bold" FontSize="16" Foreground="#228B22" 
                                                      HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            <TextBlock Text="件" FontSize="9" HorizontalAlignment="Center" Foreground="#228B22"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- NG Material Inventory -->
                                    <Border Grid.Column="2" Background="#FFF0F0" Margin="1" Padding="6,8" CornerRadius="4" BorderBrush="#FFB6C1" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="NG料库存" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" Foreground="#DC143C"/>
                                            <TextBlock Text="{Binding MaterialNG_Count, FallbackValue='12'}" 
                                                      FontWeight="Bold" FontSize="16" Foreground="#DC143C" 
                                                      HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            <TextBlock Text="件" FontSize="9" HorizontalAlignment="Center" Foreground="#DC143C"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                
                                <!-- Total and Capacity -->
                                <Border Grid.Row="1" Background="#F8F9FA" Margin="2,6,2,2" Padding="8,6" CornerRadius="3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                            <TextBlock Text="总库存:" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TotalMaterialCount, FallbackValue='251'}" 
                                                      FontWeight="Bold" FontSize="13" Foreground="#0066CC" 
                                                      Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="件" FontSize="10" Margin="2,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <Rectangle Grid.Column="1" Width="1" Fill="#CCCCCC" Margin="8,2"/>
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="满载:" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding MaxCapacity, FallbackValue='1500'}" 
                                                      FontWeight="Bold" FontSize="13" Foreground="#666666" 
                                                      Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="件" FontSize="10" Margin="2,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                
                                <!-- Status and Alert -->
                                <Border Grid.Row="2" Background="#E8F5E8" Margin="2" Padding="6,4" CornerRadius="3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="库存状态:" FontSize="10" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding InventoryStatusText, FallbackValue='正常'}" 
                                                      FontSize="10" FontWeight="Bold" Foreground="#228B22"
                                                      Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="更新:" FontSize="9" Foreground="#666666" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding LastUpdateTime, FallbackValue='14:32'}" 
                                                      FontSize="9" Foreground="#666666" 
                                                      Margin="3,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </GroupBox>
                        
                        <!-- Material Operation Quick Actions -->
                        <GroupBox Grid.Row="5" Header="快捷操作" Margin="2,4,2,8" Padding="8" 
                                 FontSize="12" FontWeight="Medium" Foreground="#2E5BBA">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button Grid.Column="0" Content="全部清料" 
                                       Style="{StaticResource ModernButton}" 
                                       Height="36" FontSize="12" FontWeight="Bold"
                                       Command="{Binding ClearAllMaterialsCommand}"
                                       Background="#FFE6E6" BorderBrush="#FFB6C1"
                                       ToolTip="清空所有物料" Margin="4,0"/>
                                
                                <Button Grid.Column="1" Content="重置计数" 
                                       Style="{StaticResource ModernButton}" 
                                       Height="36" FontSize="12" FontWeight="Bold"
                                       Command="{Binding ResetAllCountCommand}"
                                       Background="#E6F3FF" BorderBrush="#87CEEB"
                                       ToolTip="重置所有计数器" Margin="4,0"/>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Log Section -->
            <Grid Grid.Row="1" Margin="0,2.5,0,0">
                <controls:LogWindow/>
            </Grid>
        </Grid>
        
        <!-- Right Panel - Reserved & System Control -->
        <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <TextBlock Grid.Row="0" Text="系统控制区域" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5" FontWeight="Bold" FontSize="14"/>
                
                <!-- Reserved Content Area -->
                <Border Grid.Row="1" Background="#F8F9FA" Margin="8" CornerRadius="6" BorderBrush="#DEE2E6" BorderThickness="1">
                    <TextBlock Text="预留功能区域" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" Foreground="#6C757D"/>
                </Border>
                
                <!-- System Status Display -->
                <GroupBox Grid.Row="2" Header="系统状态" Margin="8,4" Padding="8" FontSize="12" FontWeight="Medium">
                    <StackPanel>
                        <!-- 系统运行状态 -->
                        <ewanControls:EwanIO 
                            LabelText="系统运行"
                            IsOn="{Binding SystemRunningIsOn, FallbackValue=True}"
                            IconSize="18"
                            LabelFontSize="12"
                            OnColor="{Binding SystemRunningStatus, FallbackValue=Green}"
                            OffColor="#696969"
                            ShowGlowEffect="True"
                            EnableAnimation="True"
                            Margin="2,3"/>
                        
                        <!-- 急停状态 -->
                        <ewanControls:EwanIO 
                            LabelText="急停状态"
                            IsOn="{Binding EmergencyStopIsOn, FallbackValue=False}"
                            IconSize="18"
                            LabelFontSize="12"
                            OnColor="{Binding EmergencyStopStatus, FallbackValue=Red}"
                            OffColor="#696969"
                            ShowGlowEffect="True"
                            EnableAnimation="True"
                            Margin="2,3"/>
                        
                        <!-- 报警状态 -->
                        <ewanControls:EwanIO 
                            LabelText="报警状态"
                            IsOn="{Binding AlarmIsOn, FallbackValue=False}"
                            IconSize="18"
                            LabelFontSize="12"
                            OnColor="{Binding AlarmStatus, FallbackValue=Red}"
                            OffColor="#696969"
                            ShowGlowEffect="True"
                            EnableAnimation="True"
                            Margin="2,3"/>
                        
                        <!-- 暂停状态 -->
                        <ewanControls:EwanIO 
                            LabelText="暂停状态"
                            IsOn="{Binding PauseIsOn, FallbackValue=False}"
                            IconSize="18"
                            LabelFontSize="12"
                            OnColor="{Binding PauseStatus, FallbackValue=Yellow}"
                            OffColor="#696969"
                            ShowGlowEffect="True"
                            EnableAnimation="True"
                            Margin="2,3"/>
                        
                        <!-- 生产模式状态 -->
                        <ewanControls:EwanIO 
                            LabelText="{Binding ProductionModeText, FallbackValue='自动模式'}"
                            IsOn="True"
                            IconSize="18"
                            LabelFontSize="12"
                            LabelFontWeight="Bold"
                            OnColor="{Binding ProductionModeColor, FallbackValue=Blue}"
                            OffColor="#696969"
                            ShowGlowEffect="True"
                            EnableAnimation="True"
                            Margin="2,3"/>
                    </StackPanel>
                </GroupBox>
                
                <!-- System Control Buttons -->
                <GroupBox Grid.Row="3" Header="系统控制" Margin="8,4,8,8" Padding="8" FontSize="12" FontWeight="Medium">
                    <StackPanel>
                        <!-- 复位按钮 -->
                        <Button Content="复位"
                                Style="{StaticResource IndustrialTestButton}"
                                Background="#6C757D"
                                FontSize="12"
                                Height="35"
                                Command="{Binding SystemResetCommand}"
                                Margin="4,2"/>
                                
                        <!-- 急停按钮 -->
                        <Button Content="急停"
                                Style="{StaticResource IndustrialTestButton}"
                                Background="#DC3545"
                                FontSize="12"
                                Height="35"
                                Command="{Binding EmergencyStopCommand}"
                                Margin="4,2"/>
                                
                        <!-- 清除报警按钮 -->
                        <Button Content="清除报警"
                                Style="{StaticResource IndustrialTestButton}"
                                Background="#FD7E14"
                                FontSize="12"
                                Height="35"
                                Command="{Binding ClearAlarmCommand}"
                                Margin="4,2"/>
                        
                        <!-- 启动按钮 -->
                        <Button Content="启动"
                                Style="{StaticResource IndustrialTestButton}"
                                Background="#28A745"
                                FontSize="12"
                                Height="35"
                                Command="{Binding SystemStartCommand}"
                                Margin="4,2"/>
                                
                        <!-- 暂停按钮 -->
                        <Button Content="暂停"
                                Style="{StaticResource IndustrialTestButton}"
                                Background="#FFC107"
                                FontSize="12"
                                Height="35"
                                Command="{Binding SystemPauseCommand}"
                                Margin="4,2"/>
                                
                        <!-- 停止按钮 -->
                        <Button Content="停止"
                                Style="{StaticResource IndustrialTestButton}"
                                Background="#DC3545"
                                FontSize="12"
                                Height="35"
                                Command="{Binding SystemStopCommand}"
                                Margin="4,2"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
