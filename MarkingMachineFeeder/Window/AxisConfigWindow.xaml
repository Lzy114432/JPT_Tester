<Window x:Class="MarkingMachineFeeder.Windows.AxisConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MarkingMachineFeeder.Viewmodel"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:AxisConfigViewModel, IsDesignTimeCreatable=True}"
        Title="{Binding WindowTitle, FallbackValue=轴参数配置}" 
        Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Name="AxisConfigWindowView">
    
    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- 通用样式定义 -->
        <Style x:Key="SimpleDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="微软雅黑"/>
        </Style>
        
        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#4682B4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#36648B"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        
        <Style x:Key="SimpleButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#4682B4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="微软雅黑"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="3">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.2" ShadowDepth="1" BlurRadius="3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5A9FD4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A6FA4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="微软雅黑"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#4682B4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#4682B4" CornerRadius="3,3,0,0" Padding="8,4">
                                <ContentPresenter ContentSource="Header" 
                                                TextBlock.Foreground="White"
                                                TextBlock.FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Row="1" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="2,0,2,2"
                                    CornerRadius="0,0,3,3"
                                    Background="White"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="微软雅黑"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Focusable="False"
                                        HorizontalScrollBarVisibility="Hidden"
                                        VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#4682B4"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <!-- 主容器 -->
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 主内容区域 -->
        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：轴列表 -->
            <GroupBox Grid.Column="0" Header="{Binding AxisParametersText, FallbackValue=轴参数配置}" 
                      Style="{StaticResource GroupBoxStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 工具栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5,0,10">
                        <Button Content="{Binding AddAxisText, FallbackValue=添加轴}" 
                                Command="{Binding AddAxisCommand}"
                                Style="{StaticResource SimpleButton}" Width="80"/>
                        <Button Content="{Binding RemoveAxisText, FallbackValue=删除轴}" 
                                Command="{Binding RemoveAxisCommand}"
                                Style="{StaticResource SimpleButton}" Width="80"
                                Background="#CD5C5C"/>
                    </StackPanel>
                    
                    <!-- 轴参数表格 -->
                    <DataGrid Grid.Row="1" x:Name="AxisDataGrid"
                              ItemsSource="{Binding AxisParameters}"
                              SelectedItem="{Binding SelectedAxis}"
                              Style="{StaticResource SimpleDataGrid}"
                              ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}">
                        <DataGrid.Columns>
                            <!-- 轴号列 -->
                            <DataGridTextColumn Header="{Binding DataContext.AxisIDHeaderText, ElementName=AxisConfigWindowView, FallbackValue=轴号}" 
                                                Binding="{Binding AxisID}" 
                                                Width="60"
                                                IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <!-- 使能状态列 -->
                            <DataGridTemplateColumn Header="{Binding DataContext.EnabledHeaderText, ElementName=AxisConfigWindowView, FallbackValue=使能}"
                                                    Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsUsing, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- 位置限制列 -->
                            <DataGridTemplateColumn Header="位置范围" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:F1}~{1:F1}">
                                                    <Binding Path="MinPos"/>
                                                    <Binding Path="MaxPos"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- 运动方向列 -->
                            <DataGridTemplateColumn Header="{Binding DataContext.MotionDirHeaderText, ElementName=AxisConfigWindowView, FallbackValue=运动方向}"
                                                    Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MotionDir}" Value="Positive">
                                                            <Setter Property="Text" Value="正向"/>
                                                            <Setter Property="Foreground" Value="#008000"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding MotionDir}" Value="Negative">
                                                            <Setter Property="Text" Value="负向"/>
                                                            <Setter Property="Foreground" Value="#FF4500"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
            
            <!-- 右侧：详细配置 -->
            <GroupBox Grid.Column="1" Header="详细配置" Style="{StaticResource GroupBoxStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        
                        <!-- 未选择轴时的提示 -->
                        <TextBlock Text="请先添加轴或选择左侧轴进行配置" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#666666"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   Margin="50"
                                   Visibility="{Binding HasNoSelectedAxis, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        
                        <!-- 选择轴后的详细配置 -->
                        <StackPanel Visibility="{Binding HasSelectedAxis, Converter={StaticResource BooleanToVisibilityConverter}}">
                        
                        <!-- 基本参数 -->
                        <GroupBox Header="基本参数" Style="{StaticResource GroupBoxStyle}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 轴号 -->
                                <Label Grid.Row="0" Grid.Column="0" Content="轴号:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAxis.AxisID}" 
                                         Style="{StaticResource ConfigTextBox}" IsReadOnly="True"/>
                                
                                <!-- 使能状态 -->
                                <Label Grid.Row="0" Grid.Column="2" Content="使能:" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="0" Grid.Column="3" IsChecked="{Binding SelectedAxis.IsUsing}" 
                                          VerticalAlignment="Center"/>
                                
                                <!-- 最大位置 -->
                                <Label Grid.Row="1" Grid.Column="0" Content="最大位置(mm):" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAxis.MaxPos}" 
                                         Style="{StaticResource ConfigTextBox}"/>
                                
                                <!-- 最小位置 -->
                                <Label Grid.Row="1" Grid.Column="2" Content="最小位置(mm):" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding SelectedAxis.MinPos}" 
                                         Style="{StaticResource ConfigTextBox}"/>
                                
                                <!-- 运动方向 -->
                                <Label Grid.Row="2" Grid.Column="0" Content="运动方向:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" 
                                          ItemsSource="{Binding MotionDirOptions}"
                                          SelectedValue="{Binding SelectedAxis.MotionDir}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="Display"
                                          Height="28"/>
                            </Grid>
                        </GroupBox>
                        
                        <!-- 速度配置 -->
                        <GroupBox Header="速度配置" Style="{StaticResource GroupBoxStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 脉冲当量 -->
                                <Label Grid.Row="0" Grid.Column="0" Content="脉冲当量:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAxis.Step}" 
                                         Style="{StaticResource ConfigTextBox}"/>
                                
                                <!-- 速度 -->
                                <Label Grid.Row="0" Grid.Column="2" Content="速度(mm/s):" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding SelectedAxis.Speed}" 
                                         Style="{StaticResource ConfigTextBox}"/>
                                
                                <!-- 加速度 -->
                                <Label Grid.Row="1" Grid.Column="0" Content="加速度(mm/s²):" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAxis.Acc}" 
                                         Style="{StaticResource ConfigTextBox}"/>
                                
                                <!-- 减速度 -->
                                <Label Grid.Row="2" Grid.Column="0" Content="减速度(mm/s²):" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAxis.Dec}" 
                                         Style="{StaticResource ConfigTextBox}"/>
                                
                            </Grid>
                        </GroupBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
        
        <!-- 底部按钮区 -->
        <Border Grid.Row="1" Background="#E8E8E8" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        Margin="10">
                <Button Content="{Binding OKText, FallbackValue=确定}" 
                        Command="{Binding OKCommand}"
                        Style="{StaticResource SimpleButton}"
                        Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>