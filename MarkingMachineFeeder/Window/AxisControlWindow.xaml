<Window x:Class="MarkingMachineFeeder.Windows.AxisControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MarkingMachineFeeder.Viewmodel"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:AxisControlViewModel, IsDesignTimeCreatable=True}"
        Title="{Binding WindowTitle, FallbackValue=轴手动控制}" 
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Name="AxisControlWindowView">
    
    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- 通用样式定义 -->
        <Style x:Key="SimpleDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="微软雅黑"/>
        </Style>
        
        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#4682B4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#36648B"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        
        <Style x:Key="ControlButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Background" Value="#4682B4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="微软雅黑"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="3">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.2" ShadowDepth="1" BlurRadius="3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5A9FD4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A6FA4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EmergencyButton" TargetType="Button" BasedOn="{StaticResource ControlButton}">
            <Setter Property="Background" Value="#DC143C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF6347"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B22222"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="微软雅黑"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#4682B4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#4682B4" CornerRadius="3,3,0,0" Padding="8,4">
                                <ContentPresenter ContentSource="Header" 
                                                TextBlock.Foreground="White"
                                                TextBlock.FontWeight="SemiBold"/>
                            </Border>
                            <Border Grid.Row="1" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="2,0,2,2"
                                    CornerRadius="0,0,3,3"
                                    Background="White"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="JogButton" TargetType="Button" BasedOn="{StaticResource ControlButton}">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>
    
    <!-- 主容器 -->
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 主内容区域 -->
        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="600"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：轴状态列表 -->
            <GroupBox Grid.Column="0" Header="{Binding AxisStatusText, FallbackValue=轴状态信息}" 
                      Style="{StaticResource GroupBoxStyle}">
                <DataGrid x:Name="AxisStatusDataGrid"
                          ItemsSource="{Binding AxisConfigs}"
                          SelectedItem="{Binding SelectedAxis}"
                          Style="{StaticResource SimpleDataGrid}"
                          ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}">
                    <DataGrid.Columns>
                        <!-- 轴号列 -->
                        <DataGridTextColumn Header="{Binding DataContext.AxisIDHeaderText, ElementName=AxisControlWindowView, FallbackValue=轴号}" 
                                            Binding="{Binding AxisID}" 
                                            Width="50"
                                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <!-- 使能状态列 -->
                        <DataGridTemplateColumn Header="{Binding DataContext.EnabledHeaderText, ElementName=AxisControlWindowView, FallbackValue=使能}"
                                                Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatusText}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUsing}" Value="True">
                                                        <Setter Property="Text" Value="启用"/>
                                                        <Setter Property="Foreground" Value="#008000"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsUsing}" Value="False">
                                                        <Setter Property="Text" Value="禁用"/>
                                                        <Setter Property="Foreground" Value="#FF4500"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- 报警状态列 -->
                        <DataGridTemplateColumn Header="报警" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatusText}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlarm}" Value="True">
                                                        <Setter Property="Text" Value="报警"/>
                                                        <Setter Property="Foreground" Value="#DC143C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsAlarm}" Value="False">
                                                        <Setter Property="Text" Value="正常"/>
                                                        <Setter Property="Foreground" Value="#008000"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- 忙碌状态列 -->
                        <DataGridTemplateColumn Header="状态" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatusText}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                        <Setter Property="Text" Value="运行"/>
                                                        <Setter Property="Foreground" Value="#FFA500"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsBusy}" Value="False">
                                                        <Setter Property="Text" Value="停止"/>
                                                        <Setter Property="Foreground" Value="#008000"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- 当前位置列 -->
                        <DataGridTemplateColumn Header="位置(mm)" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Position, StringFormat=F2}" 
                                               TextAlignment="Center" 
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- 速度列 -->
                        <DataGridTemplateColumn Header="速度(mm/s)" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Speed, StringFormat=F0}" 
                                               TextAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
            
            <!-- 右侧：轴控制区域 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 全局控制按钮 -->
                <GroupBox Grid.Row="0" Header="全局控制" Style="{StaticResource GroupBoxStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="全部使能" Command="{Binding EnableAllCommand}" Style="{StaticResource ControlButton}" Width="100"/>
                        <Button Content="全部禁用" Command="{Binding DisableAllCommand}" Style="{StaticResource ControlButton}" Width="100"/>
                        <Button Content="全部停止" Command="{Binding StopAllCommand}" Style="{StaticResource EmergencyButton}" Width="100"/>
                        <Button Content="急停" Command="{Binding EmergencyStopCommand}" Style="{StaticResource EmergencyButton}" Width="100"/>
                    </StackPanel>
                </GroupBox>
                
                <!-- 单轴控制区域 -->
                <GroupBox Grid.Row="1" Header="单轴控制" Style="{StaticResource GroupBoxStyle}">
                    <Grid>
                        <!-- 未选择轴时的提示 -->
                        <TextBlock Text="请先选择左侧轴进行控制" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#666666"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   Visibility="{Binding HasNoSelectedAxis, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        
                        <!-- 选择轴后的控制界面 -->
                        <StackPanel Visibility="{Binding HasSelectedAxis, Converter={StaticResource BooleanToVisibilityConverter}}">
                            
                            <!-- 轴信息显示 -->
                            <Border Background="#E8F4FD" BorderBrush="#4682B4" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="轴号: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding SelectedAxis.AxisID}" FontWeight="Bold" Foreground="#4682B4"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="位置: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding SelectedAxis.Position, StringFormat=F2}" FontWeight="Bold" Foreground="#4682B4"/>
                                        <TextBlock Text=" mm" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="速度: " FontWeight="Bold"/>
                                        <TextBlock Text="{Binding SelectedAxis.Speed, StringFormat=F0}" FontWeight="Bold" Foreground="#4682B4"/>
                                        <TextBlock Text=" mm/s" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- 轴控制按钮组 -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 使能控制 -->
                                <GroupBox Grid.Row="0" Header="使能控制" Style="{StaticResource GroupBoxStyle}" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="使能" Command="{Binding EnableAxisCommand}" Style="{StaticResource ControlButton}" Width="100"/>
                                        <Button Content="禁用" Command="{Binding DisableAxisCommand}" Style="{StaticResource ControlButton}" Width="100"/>
                                    </StackPanel>
                                </GroupBox>
                                
                                <!-- 点动控制 -->
                                <GroupBox Grid.Row="1" Header="点动控制" Style="{StaticResource GroupBoxStyle}" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- 点动速度设置 -->
                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="点动速度(mm/s):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding JogSpeed, UpdateSourceTrigger=PropertyChanged}" 
                                                     Height="28" VerticalContentAlignment="Center" TextAlignment="Center"/>
                                        </Grid>
                                        
                                        <!-- 点动按钮 -->
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Button Grid.Column="0" Content="负向" 
                                                    Command="{Binding JogNegativeCommand}" 
                                                    Style="{StaticResource JogButton}"
                                                    HorizontalAlignment="Right" Margin="0,0,20,0"/>
                                            <Button Grid.Column="1" Content="停止" 
                                                    Command="{Binding JogStopCommand}" 
                                                    Style="{StaticResource EmergencyButton}"
                                                    Width="80" Height="60"/>
                                            <Button Grid.Column="2" Content="正向" 
                                                    Command="{Binding JogPositiveCommand}" 
                                                    Style="{StaticResource JogButton}"
                                                    HorizontalAlignment="Left" Margin="20,0,0,0"/>
                                        </Grid>
                                    </Grid>
                                </GroupBox>
                                
                                <!-- 定位控制 -->
                                <GroupBox Grid.Row="2" Header="定位控制" Style="{StaticResource GroupBoxStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- 目标位置输入 -->
                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="目标位置(mm):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding TargetPosition, UpdateSourceTrigger=PropertyChanged}" 
                                                     Height="28" VerticalContentAlignment="Center" TextAlignment="Center"/>
                                            <Button Grid.Column="2" Content="移动" Command="{Binding AbsMoveCommand}" 
                                                    Style="{StaticResource ControlButton}" Margin="10,0,0,0" Width="100"/>
                                        </Grid>
                                        
                                        <!-- 快捷位置按钮 -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="回零点" Command="{Binding MoveToZeroCommand}" Style="{StaticResource ControlButton}" Width="100"/>
                                            <Button Content="最小位置" Command="{Binding MoveToMinCommand}" Style="{StaticResource ControlButton}" Width="100"/>
                                            <Button Content="最大位置" Command="{Binding MoveToMaxCommand}" Style="{StaticResource ControlButton}" Width="100"/>
                                        </StackPanel>
                                    </Grid>
                                </GroupBox>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>
        
        <!-- 底部按钮区 -->
        <Border Grid.Row="1" Background="#E8E8E8" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        Margin="10">
                <Button Content="刷新状态" Command="{Binding RefreshStatusCommand}" Style="{StaticResource ControlButton}" Width="100" Margin="5"/>
                <Button Content="关闭" Command="{Binding CloseCommand}" Style="{StaticResource ControlButton}" Width="100" Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>