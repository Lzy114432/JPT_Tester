<Window x:Class="MarkingMachineFeeder.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录" Height="350" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Title -->
        <TextBlock Grid.Row="0" Text="系统登录" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        
        <!-- Username Label -->
        <TextBlock Grid.Row="2" Text="用户名:" FontSize="12"/>
        <!-- Username TextBox -->
        <TextBox Grid.Row="3" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="30" FontSize="12"/>
        
        <!-- Password Label -->
        <TextBlock Grid.Row="5" Text="密码:" FontSize="12"/>
        <!-- Password Box -->
        <PasswordBox Grid.Row="6" x:Name="PasswordBox" Height="30" FontSize="12"/>
        
        <!-- Error Message -->
        <TextBlock Grid.Row="8" 
                  Text="{Binding ErrorMessage}" 
                  Foreground="Red" 
                  FontSize="11" 
                  TextWrapping="Wrap"
                  Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        
        <!-- Login Button -->
        <Button Grid.Row="10" 
               Content="登录" 
               Command="{Binding LoginCommand}"
               CommandParameter="{Binding ElementName=PasswordBox}"
               Height="35"
               Background="Green"
               Foreground="White"
               FontSize="14"
               FontWeight="Bold"/>
        
        <!-- User Info -->
        <TextBlock Grid.Row="12" 
                  Text="默认用户: admin/123456, engineer/123456, operator/123456" 
                  FontSize="10" 
                  Foreground="Gray" 
                  HorizontalAlignment="Center" 
                  TextWrapping="Wrap"
                  TextAlignment="Center"/>
    </Grid>
</Window>