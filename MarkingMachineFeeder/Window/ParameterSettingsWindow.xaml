<Window x:Class="MarkingMachineFeeder.Windows.ParameterSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MarkingMachineFeeder.Viewmodel"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        d:DataContext="{d:DesignInstance Type=vm:ParameterSettingsViewModel, IsDesignTimeCreatable=True}">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- 渐变背景画刷 - SteelBlue 风格 -->
        <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4682B4" Offset="0"/>
            <GradientStop Color="#2F4F4F" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- 现代文本框样式 -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#495057"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        VerticalAlignment="Center"
                                        Margin="14,0,15,0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalScrollBarVisibility="Hidden"
                                        VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#4682B4"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 现代按钮样式 - SteelBlue 风格 -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4682B4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5A9FD4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#36648B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#B0C4DE"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Secondary button style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#4682B4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#4682B4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F4FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D0E4F7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F5F5F5"/>
                                <Setter Property="Foreground" Value="#B0B0B0"/>
                                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 复选框样式 -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#495057"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckBorder" Grid.Column="0"
                                    Width="18" Height="18"
                                    Background="White"
                                    BorderBrush="#4682B4"
                                    BorderThickness="2"
                                    CornerRadius="3"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M2,6 L6,10 L14,2"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" 
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#4682B4"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#5A9FD4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 标题样式 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="Foreground" Value="#4682B4"/>
        </Style>
        
        <!-- Card style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" Direction="270" Opacity="0.1" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <!-- 主容器，带圆角和阴影 -->
    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="25" Opacity="0.25" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>  <!-- Header区域 -->
                <RowDefinition Height="*"/>    <!-- 内容区域 -->
                <RowDefinition Height="Auto"/> <!-- 底部按钮区域 -->
            </Grid.RowDefinitions>
            
            <!-- 渐变背景头部 -->
            <Border Grid.Row="0" Background="{StaticResource BackgroundGradient}" CornerRadius="20,20,0,0">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Logo或图标 -->
                        <Ellipse Width="45" Height="45" Fill="White" Opacity="0.2" Margin="0,0,0,8"/>
                        <TextBlock Text="⚙" FontSize="24" HorizontalAlignment="Center" Margin="0,-40,0,12"/>
                        
                        <!-- 标题 -->
                        <TextBlock Text="系统参数设置"
                                  FontSize="22" 
                                  FontWeight="Bold" 
                                  Foreground="White" 
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="配置系统运行参数"
                                  FontSize="13" 
                                  Foreground="White" 
                                  Opacity="0.85"
                                  HorizontalAlignment="Center" 
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <!-- 关闭按钮 -->
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Top" 
                            Width="35" Height="35" 
                            Margin="15,15,15,0"
                            Background="Transparent" 
                            BorderThickness="0" 
                            Foreground="White" 
                            FontSize="18"
                            Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#FFFFFF30"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
            
            <!-- 主内容区域 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="30,20">
                <StackPanel>
                    <!-- 运行模式设置 -->
                    <Border Style="{StaticResource CardBorder}" Padding="25" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{Binding RunModeTitle, FallbackValue='运行模式'}"
                                      Style="{StaticResource SectionTitle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 左侧列：基础开关和料仓选择 -->
                                <StackPanel Grid.Column="0">
                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <CheckBox Content="{Binding EnableLoadingLabel, FallbackValue='启用上料模块'}"
                                                 IsChecked="{Binding EnableLoadingModule}"
                                                 Style="{StaticResource ModernCheckBox}"/>
                                    </Border>

                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <CheckBox Content="{Binding EnableUnloadingLabel, FallbackValue='启用下料模块'}"
                                                 IsChecked="{Binding EnableUnloadingModule}"
                                                 Style="{StaticResource ModernCheckBox}"/>
                                    </Border>

                                    <!-- 装料料仓选择 -->
                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding LoadingBinSelectionLabel, FallbackValue='装料料仓选择'}"
                                                      FontSize="14"
                                                      FontWeight="Medium"
                                                      Foreground="#495057"
                                                      Margin="0,0,0,10"/>
                                            <ComboBox ItemsSource="{Binding BinOptions}"
                                                      SelectedValuePath="Value"
                                                      DisplayMemberPath="Display"
                                                      SelectedValue="{Binding LoadingSelectedBin, Mode=TwoWay}"
                                                      Height="40"
                                                      FontSize="14"
                                                      Padding="12,0"
                                                      Background="#F8F9FA"
                                                      BorderBrush="#E9ECEF"
                                                      BorderThickness="1"
                                                      HorizontalContentAlignment="Left"
                                                      VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- 下料料仓选择 -->
                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="{Binding UnloadingBinSelectionLabel, FallbackValue='下料料仓选择'}"
                                                      FontSize="14"
                                                      FontWeight="Medium"
                                                      Foreground="#495057"
                                                      Margin="0,0,0,10"/>
                                            <ComboBox ItemsSource="{Binding BinOptions}"
                                                      SelectedValuePath="Value"
                                                      DisplayMemberPath="Display"
                                                      SelectedValue="{Binding UnloadingSelectedBin, Mode=TwoWay}"
                                                      Height="40"
                                                      FontSize="14"
                                                      Padding="12,0"
                                                      Background="#F8F9FA"
                                                      BorderBrush="#E9ECEF"
                                                      BorderThickness="1"
                                                      HorizontalContentAlignment="Left"
                                                      VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- 右侧列：高级选项和数值设置 -->
                                <StackPanel Grid.Column="2">
                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <CheckBox Content="{Binding HighSpeedModeLabel, FallbackValue='启用高速运行模式'}"
                                                     IsChecked="{Binding HighSpeedModeEnabled}"
                                                     Style="{StaticResource ModernCheckBox}"/>
                                            <TextBlock Text="{Binding HighSpeedModeDesc, FallbackValue='启用后系统将在启动时自动切换到高速运行模式'}" 
                                                      FontSize="12" 
                                                      Foreground="#9CA3AF" 
                                                      Margin="28,5,0,0"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <CheckBox Content="{Binding SafetyDoorBypassLabel, FallbackValue='安全门报警屏蔽'}"
                                                     IsChecked="{Binding SafetyDoorAlarmBypass}"
                                                     Style="{StaticResource ModernCheckBox}"/>
                                            <TextBlock Text="{Binding SafetyDoorBypassDesc, FallbackValue='勾选后启动将忽略安全门状态，不触发安全门报警'}"
                                                      FontSize="12"
                                                      Foreground="#9CA3AF"
                                                      Margin="28,5,0,0"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="小车检测模式"
                                                      FontSize="14"
                                                      FontWeight="Medium"
                                                      Foreground="#495057"
                                                      Margin="0,0,0,10"/>
                                            
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <RadioButton Content="保持空车数量" 
                                                            IsChecked="{Binding IsEmptyCartMode, Mode=TwoWay}"
                                                            GroupName="CartCheckMode"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,20,0"/>
                                                <RadioButton Content="保持切栈桥小车数量"
                                                            IsChecked="{Binding IsCuttingBridgeCarMode, Mode=TwoWay}"
                                                            GroupName="CartCheckMode"
                                                            VerticalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <StackPanel Visibility="{Binding IsEmptyCartMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBox Text="{Binding EmptyCartReserveCount, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource ModernTextBox}"/>
                                                <TextBlock Text="当空车数量 ≤ 该值时，系统自动下空车"
                                                          FontSize="12"
                                                          Foreground="#9CA3AF"
                                                          Margin="0,5,0,0"
                                                          TextWrapping="Wrap"/>
                                            </StackPanel>
                                            
                                            <StackPanel Visibility="{Binding IsCuttingBridgeCarMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBox Text="{Binding CuttingBridgeCarReserveCount, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource ModernTextBox}"/>
                                                <TextBlock Text="当切栈桥车数量 > 该值时，系统自动下空车"
                                                          FontSize="12"
                                                          Foreground="#9CA3AF"
                                                          Margin="0,5,0,0"
                                                          TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- 时序参数设置 -->
                    <Border Style="{StaticResource CardBorder}" Padding="25">
                        <StackPanel>
                            <TextBlock Text="{Binding TimingParametersTitle, FallbackValue='时序参数'}"
                                      Style="{StaticResource SectionTitle}"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 系统复位延迟 -->
                                <Border Grid.Row="0" Grid.Column="0" Background="#FAFAFA" CornerRadius="8" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SystemResetDelayLabel, FallbackValue='系统复位延迟时间 (毫秒)'}"
                                                  FontSize="14" 
                                                  FontWeight="Medium" 
                                                  Foreground="#495057"
                                                  Margin="0,0,0,10"/>
                                        
                                        <TextBox Text="{Binding ResetDelayMs, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource ModernTextBox}"/>
                                        
                                        <TextBlock Text="{Binding SystemResetDelayDesc, FallbackValue='系统复位初始化完成后的等待时间'}"
                                                  FontSize="12" 
                                                  Foreground="#9CA3AF"
                                                  Margin="0,5,0,0"
                                                  TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- 低速模式设置延迟 -->
                                <Border Grid.Row="0" Grid.Column="2" Background="#FAFAFA" CornerRadius="8" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="{Binding LowSpeedSetupDelayLabel, FallbackValue='低速模式设置延迟 (毫秒)'}"
                                                  FontSize="14" 
                                                  FontWeight="Medium" 
                                                  Foreground="#495057"
                                                  Margin="0,0,0,10"/>
                                        
                                        <TextBox Text="{Binding LowSpeedSetupDelayMs, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource ModernTextBox}"/>
                                        
                                        <TextBlock Text="{Binding LowSpeedSetupDelayDesc, FallbackValue='设置低速运行模式后的等待时间'}"
                                                  FontSize="12" 
                                                  Foreground="#9CA3AF"
                                                  Margin="0,5,0,0"
                                                  TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- 环线上料超时时间 -->
                                <Border Grid.Row="2" Grid.Column="0" Background="#FAFAFA" CornerRadius="8" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="{Binding RingLineTimeoutLabel, FallbackValue='环线上料请求超时时间 (秒)'}"
                                                  FontSize="14" 
                                                  FontWeight="Medium" 
                                                  Foreground="#495057"
                                                  Margin="0,0,0,10"/>
                                        
                                        <TextBox Text="{Binding RingLineTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource ModernTextBox}"/>
                                        
                                        <TextBlock Text="{Binding RingLineTimeoutDesc, FallbackValue='环线上料请求等待响应的超时时间'}"
                                                  FontSize="12" 
                                                  Foreground="#9CA3AF"
                                                  Margin="0,5,0,0"
                                                  TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- MES 参数设置 -->
                    <Border Style="{StaticResource CardBorder}" Padding="25" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="MES 参数"
                                      Style="{StaticResource SectionTitle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <CheckBox Content="启用 MES"
                                                 IsChecked="{Binding MesEnabled}"
                                                 Style="{StaticResource ModernCheckBox}"/>
                                    </Border>

                                    <StackPanel IsEnabled="{Binding MesEnabled}">
                                        <Border Background="#FAFAFA" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="Broker 地址"
                                                          FontSize="14"
                                                          FontWeight="Medium"
                                                          Foreground="#495057"
                                                          Margin="0,0,0,10"/>
                                                <TextBox Text="{Binding MesBrokerHost, UpdateSourceTrigger=PropertyChanged}"
                                                        Style="{StaticResource ModernTextBox}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#FAFAFA" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="Broker 端口"
                                                          FontSize="14"
                                                          FontWeight="Medium"
                                                          Foreground="#495057"
                                                          Margin="0,0,0,10"/>
                                                <TextBox Text="{Binding MesBrokerPort, UpdateSourceTrigger=PropertyChanged}"
                                                        Style="{StaticResource ModernTextBox}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#FAFAFA" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="扫码重试次数"
                                                          FontSize="14"
                                                          FontWeight="Medium"
                                                          Foreground="#495057"
                                                          Margin="0,0,0,10"/>
                                                <TextBox Text="{Binding CodeReaderScanRetryCount, UpdateSourceTrigger=PropertyChanged}"
                                                        Style="{StaticResource ModernTextBox}"/>
                                                <TextBlock Text="超过次数仍未扫码到则继续流程"
                                                          FontSize="12"
                                                          Foreground="#9CA3AF"
                                                          Margin="0,5,0,0"
                                                          TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#FAFAFA" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="用户名"
                                                          FontSize="14"
                                                          FontWeight="Medium"
                                                          Foreground="#495057"
                                                          Margin="0,0,0,10"/>
                                                <TextBox Text="{Binding MesUserName, UpdateSourceTrigger=PropertyChanged}"
                                                        Style="{StaticResource ModernTextBox}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#FAFAFA" CornerRadius="8" Padding="20">
                                            <StackPanel>
                                                <TextBlock Text="密码"
                                                          FontSize="14"
                                                          FontWeight="Medium"
                                                          Foreground="#495057"
                                                          Margin="0,0,0,10"/>
                                                <TextBox Text="{Binding MesPassword, UpdateSourceTrigger=PropertyChanged}"
                                                        Style="{StaticResource ModernTextBox}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" IsEnabled="{Binding MesEnabled}">
                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <CheckBox Content="CleanSession"
                                                 IsChecked="{Binding MesCleanSession}"
                                                 Style="{StaticResource ModernCheckBox}"/>
                                    </Border>

                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="KeepAlive (秒)"
                                                      FontSize="14"
                                                      FontWeight="Medium"
                                                      Foreground="#495057"
                                                      Margin="0,0,0,10"/>
                                            <TextBox Text="{Binding MesKeepAliveSeconds, UpdateSourceTrigger=PropertyChanged}"
                                                    Style="{StaticResource ModernTextBox}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="ClientId (可空)"
                                                      FontSize="14"
                                                      FontWeight="Medium"
                                                      Foreground="#495057"
                                                      Margin="0,0,0,10"/>
                                            <TextBox Text="{Binding MesClientId, UpdateSourceTrigger=PropertyChanged}"
                                                    Style="{StaticResource ModernTextBox}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="环线设备ID"
                                                      FontSize="14"
                                                      FontWeight="Medium"
                                                      Foreground="#495057"
                                                      Margin="0,0,0,10"/>
                                            <TextBox Text="{Binding MesRingLineDeviceId, UpdateSourceTrigger=PropertyChanged}"
                                                    Style="{StaticResource ModernTextBox}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FAFAFA" CornerRadius="8" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="环线设备编码"
                                                      FontSize="14"
                                                      FontWeight="Medium"
                                                      Foreground="#495057"
                                                      Margin="0,0,0,10"/>
                                            <TextBox Text="{Binding MesRingLineDeviceCode, UpdateSourceTrigger=PropertyChanged}"
                                                    Style="{StaticResource ModernTextBox}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- 底部按钮区域 -->
            <Border Grid.Row="2" Background="#F8F9FA" 
                   BorderBrush="#E9ECEF" 
                   BorderThickness="0,1,0,0" 
                   CornerRadius="0,0,20,20"
                   Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="保存"
                           Command="{Binding SaveCommand}" 
                           Style="{StaticResource ModernButton}" 
                           Margin="0,0,5,0"/>
                    <Button Content="应用"
                           Command="{Binding ApplyCommand}" 
                           Style="{StaticResource ModernButton}" 
                           Margin="0,0,5,0"/>
                    <Button Content="取消"
                           Command="{Binding CancelCommand}" 
                           Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
