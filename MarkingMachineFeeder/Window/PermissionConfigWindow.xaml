<Window x:Class="MarkingMachineFeeder.Windows.PermissionConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MarkingMachineFeeder.Viewmodel"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:PermissionConfigViewModel, IsDesignTimeCreatable=False}">
    
    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            
            <!-- Modern color scheme -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#2196F3"/>
        <SolidColorBrush x:Key="PrimaryDarkColor" Color="#1976D2"/>
        <SolidColorBrush x:Key="AccentColor" Color="#03A9F4"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#212121"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#757575"/>
        
        <!-- 复选框样式 -->
        <Style x:Key="PermissionCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- 标题样式 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,8"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
        </Style>
        
        <!-- Card style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" Direction="270" Opacity="0.1" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 按钮样式 -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDarkColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                                <Setter Property="Foreground" Value="#9E9E9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Secondary button style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid Background="{StaticResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题区域 -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Padding="20,15">
            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}" FontSize="22" FontWeight="Light" Foreground="White"/>
                <TextBlock Text="{Binding WindowDescription}" FontSize="13" Foreground="#E3F2FD" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：角色/用户列表 -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 角色列表 -->
                    <TextBlock Grid.Row="0" Text="{Binding RoleListTitle}" Style="{StaticResource SectionTitle}" Margin="15,15,15,5"/>
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding Roles}" 
                             SelectedItem="{Binding SelectedRole}"
                             Margin="15,0,15,10"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0,2" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding RoleDisplayName}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding RoleName}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <!-- 用户列表 -->
                    <TextBlock Grid.Row="2" Text="{Binding UserSpecialPermissionsTitle}" Style="{StaticResource SectionTitle}" Margin="15,10,15,5"/>
                    <ListBox Grid.Row="3" 
                             ItemsSource="{Binding Users}" 
                             SelectedItem="{Binding SelectedUser}"
                             Margin="15,0,15,15"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0,2" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                    <Setter Property="Background" Value="#F5F5F5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Username}" Foreground="{StaticResource TextPrimary}"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            
            <!-- 右侧：权限配置 -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 当前选中项信息 -->
                        <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock FontSize="15" FontWeight="Medium" Foreground="{StaticResource TextPrimary}" Text="{Binding CurrentConfigDisplayText}"/>
                                <TextBlock Text="{Binding CurrentConfigDescription}" 
                                         FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 权限列表 -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding PermissionCategories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,8" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}" 
                                           BorderThickness="1" CornerRadius="6" Padding="15">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="3" Direction="270" Opacity="0.08" ShadowDepth="1"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <!-- 分类标题 -->
                                            <TextBlock Text="{Binding LocalizedCategoryName}" 
                                                     Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                                            
                                            <!-- 该分类下的权限 -->
                                            <ItemsControl ItemsSource="{Binding Permissions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8,6" Margin="0,2" CornerRadius="4">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#FAFAFA"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="30"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <CheckBox Grid.Column="0" 
                                                                        IsChecked="{Binding IsGranted}"
                                                                        IsEnabled="{Binding IsEditable}"
                                                                        Style="{StaticResource PermissionCheckBox}"
                                                                        VerticalAlignment="Top"
                                                                        Margin="0,2,0,0"/>
                                                                
                                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                    <TextBlock Text="{Binding LocalizedDisplayName}" 
                                                                             FontWeight="Medium" 
                                                                             FontSize="13"
                                                                             Foreground="{StaticResource TextPrimary}"/>
                                                                    <TextBlock Text="{Binding LocalizedDescription}" 
                                                                             FontSize="11" 
                                                                             Foreground="{StaticResource TextSecondary}"
                                                                             TextWrapping="Wrap"
                                                                             Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
        
        <!-- 底部按钮区域 -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="15">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="{Binding AddRoleButtonText}" Command="{Binding AddRoleCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,5,0"/>
                    <Button Content="{Binding DeleteRoleButtonText}" Command="{Binding DeleteRoleCommand}" Style="{StaticResource SecondaryButton}"/>
                    <Separator Width="1" Background="{StaticResource BorderColor}" Margin="15,5"/>
                    <Button Content="{Binding ImportConfigButtonText}" Command="{Binding ImportConfigCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,5,0"/>
                    <Button Content="{Binding ExportConfigButtonText}" Command="{Binding ExportConfigCommand}" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding ApplyButtonText}" Command="{Binding ApplyCommand}" Style="{StaticResource ActionButton}" Margin="0,0,5,0"/>
                    <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}" Style="{StaticResource ActionButton}" Margin="0,0,5,0"/>
                    <Button Content="{Binding CancelButtonText}" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>