<Window x:Class="MarkingMachineFeeder.Windows.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarkingMachineFeeder.Windows"
        mc:Ignorable="d"
        Title="{Binding Title}" 
        Height="200" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- 工业风格按钮样式 -->
        <Style x:Key="IndustrialButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#4682B4" Offset="0"/>
                        <GradientStop Color="#36648B" Offset="0.5"/>
                        <GradientStop Color="#27408B" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="true">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="1" BlurRadius="3"/>
                            </Border.Effect>
                            <ContentPresenter x:Name="contentPresenter" 
                                            Focusable="False" 
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            Margin="{TemplateBinding Padding}" 
                                            RecognizesAccessKey="True" 
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#5A5A5A" Offset="0"/>
                                            <GradientStop Color="#3D3D40" Offset="0.5"/>
                                            <GradientStop Color="#2E2E2E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="BorderBrush" Value="#777777"/>
                                <Setter Property="Foreground" Value="#FFFF00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#3A3A3A" Offset="0"/>
                                            <GradientStop Color="#1D1D20" Offset="0.5"/>
                                            <GradientStop Color="#0E0E0E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="BorderBrush" Value="#999999"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#F4F4F4"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#E0E0E0"/>
                                <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="#999999"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 确认按钮样式（绿色主题） -->
        <Style x:Key="ConfirmButton" TargetType="Button" BasedOn="{StaticResource IndustrialButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#2E8B57" Offset="0"/>
                        <GradientStop Color="#228B22" Offset="0.5"/>
                        <GradientStop Color="#006400" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#2E8B57"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#3CB371" Offset="0"/>
                                <GradientStop Color="#32CD32" Offset="0.5"/>
                                <GradientStop Color="#228B22" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#3CB371"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#228B22" Offset="0"/>
                                <GradientStop Color="#006400" Offset="0.5"/>
                                <GradientStop Color="#004D00" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 取消按钮样式（红色主题） -->
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource IndustrialButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#CD5C5C" Offset="0"/>
                        <GradientStop Color="#B22222" Offset="0.5"/>
                        <GradientStop Color="#8B0000" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#CD5C5C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#DC143C" Offset="0"/>
                                <GradientStop Color="#CD5C5C" Offset="0.5"/>
                                <GradientStop Color="#B22222" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#DC143C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#B22222" Offset="0"/>
                                <GradientStop Color="#8B0000" Offset="0.5"/>
                                <GradientStop Color="#800000" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderBrush="#555555" BorderThickness="1" Background="#F5F5F5">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.3" ShadowDepth="3" BlurRadius="10"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource BackgroundGradient}" 
                    BorderBrush="#555555" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True" Margin="10,5">
                    <Button DockPanel.Dock="Right" Content="✕" Foreground="White" 
                            Background="Transparent" BorderThickness="0" Padding="5,0" 
                            FontWeight="Bold" Click="CloseButton_Click"/>
                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="5,0"/>
                </DockPanel>
            </Border>
            
            <!-- 内容区域 -->
            <Border Grid.Row="1" Padding="20,15">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" VerticalAlignment="Center" 
                           HorizontalAlignment="Center" FontSize="14" TextAlignment="Center"/>
            </Border>
            
            <!-- 按钮区域 -->
            <Border Grid.Row="2" Background="#EFEFEF" BorderBrush="#DDDDDD" 
                    BorderThickness="0,1,0,0" Padding="15,10" CornerRadius="0,0,8,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="{Binding YesButtonText}" 
                            Style="{StaticResource ConfirmButton}" Click="YesButton_Click"/>
                    <Button Content="{Binding NoButtonText}" 
                            Style="{StaticResource IndustrialButton}" Click="NoButton_Click"/>
                    <Button Content="{Binding CancelButtonText}" 
                            Style="{StaticResource CancelButton}" Click="CancelButton_Click"
                            Visibility="{Binding CancelButtonVisibility}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>